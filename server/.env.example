APP_NAME=Platform
NODE_ENV=development
PORT=3000
SKIP_DB_CONNECT=false
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=saas_backend
JWT_SECRET=changeme
JWT_EXPIRES_IN=900s
REFRESH_TOKEN_TTL=1209600
PASSWORD_RESET_TTL=1800
RATE_LIMIT_GLOBAL_TTL=60
RATE_LIMIT_GLOBAL_LIMIT=50
RATE_LIMIT_RESET_TTL=60
RATE_LIMIT_RESET_LIMIT=1
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
EMAIL_WELCOME_ENABLED=true
EMAIL_ORDER_CONFIRMATION_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=domain.events
METRICS_ENABLED=true
METRICS_ROUTE=/metrics
RUN_SEED_ON_STARTUP=false
DOCS_ENABLED=true
DOCS_ROUTE=/docs
DOCS_TITLE=SaaS Backend API
DOCS_VERSION=1.0
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PASSWORD=admin123
